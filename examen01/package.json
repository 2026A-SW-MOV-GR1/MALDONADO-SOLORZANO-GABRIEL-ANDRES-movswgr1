    "react-dom": "18.2.0",
    "react-native": "0.71.14",
    "react-native-web": "^0.18.0",
    "@types/react": "~18.0.27",
    "typescript": "^4.9.4"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-native": "^0.72.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
